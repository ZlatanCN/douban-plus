{
  "name": "douban-plus",
  "version": "1.0.3",
  "description": "一款适配 ScriptCat / Tampermonkey 的油猴脚本，将豆瓣电影与电视剧详情页重塑为 Apple TV+ 沉浸式暗色 UI。支持模糊背景 Hero 横幅、HD 海报预览、流媒体来源卡片、演员横滑轮播、剧照墙与大图查看、短评网格、推荐作品列表，以及带评分和短评的想看/看过标记弹窗，保留所有原始豆瓣链接与经典豆瓣绿 (#41be5d) 强调色。",
  "keywords": [
    "apple-tv",
    "douban",
    "scriptcat",
    "tampermonkey",
    "userscript"
  ],
  "license": "MIT",
  "author": "Gabriel Zhu",
  "type": "module",
  "main": "douban-plus.user.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "tsx tests/qa.ts",
    "lint": "ultracite check",
    "fix": "ultracite fix",
    "format": "ultracite fix",
    "typecheck": "tsc --noEmit",
    "ci": "ultracite check && tsc --noEmit && vitest run && vite build && tsx tests/qa.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "ultracite": "^7.8.3",
    "vite": "^8.0.16",
    "vite-plugin-monkey": "^8.0.6",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
