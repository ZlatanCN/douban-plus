{
  "name": "douban-plus",
  "version": "1.5.0",
  "description": "适配 ScriptCat 和 Tampermonkey 的豆瓣作品详情页与人物页增强脚本，用 Preact 重排为 Apple TV 风格沉浸式暗色界面，并保留豆瓣原生登录、标记和跳转能力。",
  "keywords": [
    "apple-tv",
    "douban",
    "scriptcat",
    "tampermonkey",
    "userscript"
  ],
  "license": "MIT",
  "author": "Gabriel Zhu",
  "type": "module",
  "main": "douban-plus.user.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "tsx tests/qa.ts",
    "lint": "ultracite check && stylelint \"src/**/*.css\"",
    "fix": "ultracite fix && stylelint \"src/**/*.css\" --fix",
    "format": "ultracite fix",
    "typecheck": "tsc && tsc -p tests/tsconfig.json",
    "ci": "pnpm lint && tsc && tsc -p tests/tsconfig.json && vitest run && vite build && tsx tests/qa.ts"
  },
  "dependencies": {
    "motion": "^12.42.2",
    "preact": "^10.29.7"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "playwright": "^1.61.1",
    "stylelint": "^17.14.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "ultracite": "^7.9.4",
    "vite": "^8.1.4",
    "vite-plugin-monkey": "^8.0.6",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
