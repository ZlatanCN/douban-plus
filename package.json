{
  "name": "douban-plus",
  "version": "1.0.0",
  "description": "一款适配 ScriptCat / Tampermonkey 的油猴脚本，将豆瓣电影与电视剧详情页重塑为 Apple TV+ 沉浸式暗色 UI。支持模糊背景 Hero 横幅、HD 海报预览、流媒体来源卡片、演员横滑轮播、剧照墙与大图查看、短评网格、推荐作品列表，以及带评分和短评的想看/看过标记弹窗，保留所有原始豆瓣链接与经典豆瓣绿 (#41be5d) 强调色。",
  "keywords": [
    "apple-tv",
    "douban",
    "scriptcat",
    "tampermonkey",
    "userscript"
  ],
  "license": "MIT",
  "author": "Gabriel Zhu",
  "type": "module",
  "main": "douban-plus.user.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "ultracite fix && ultracite check && vite build && npx tsx tests/qa.ts",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "ultracite": "^7.8.3",
    "vite": "^8.0.16",
    "vite-plugin-monkey": "^8.0.6"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
