{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vite/client", "vite-plugin-monkey/client"],
    "noEmit": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
